# ===========================================
# GenAI Assistant with RAG - Configuration
# ===========================================

# Google Gemini API Key (Required)
# Get your key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# RAG Configuration
SIMILARITY_THRESHOLD=0.35
TOP_K=3
CHUNK_SIZE=400
CHUNK_OVERLAP=50

# LLM Configuration
LLM_TEMPERATURE=0.2
LLM_MODEL=gemini-flash-lite-latest

# Conversation Memory
MAX_HISTORY=5

# JWT Secret (for bonus authentication feature)
JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
